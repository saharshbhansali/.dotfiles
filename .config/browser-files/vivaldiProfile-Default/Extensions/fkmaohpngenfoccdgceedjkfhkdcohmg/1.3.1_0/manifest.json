{
   "action": {
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "content_scripts": [ {
      "js": [ "js/vendor.js", "js/content_script.js" ],
      "matches": [ "https://www.google.com/calendar/*", "https://calendar.google.com/calendar/*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "extension_pages": "default-src 'self'; connect-src https://api.figma.com https://figma.com https://www.figma.com https://*.sentry.io; img-src *; style-src 'unsafe-inline'; object-src 'none'"
   },
   "default_locale": "en",
   "description": "Figma",
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Figma",
   "optional_host_permissions": [ "https://www.figma.com/" ],
   "optional_permissions": [ "cookies" ],
   "permissions": [ "storage", "identity", "tabs" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.1",
   "web_accessible_resources": [ {
      "matches": [ "https://www.google.com/*", "https://calendar.google.com/*" ],
      "resources": [ "img/*.png", "font/*.woff2", "file_picker.html" ]
   } ]
}
